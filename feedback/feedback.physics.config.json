{
  "run": ".venv\\Scripts\\python.exe feedback/solve_case.py --out feedback/out",
  "cwd": ".",
  "outputs_dir": "feedback/out",
  "results_file": "feedback/out/results.json",
  "oracle_file": "feedback/oracle.physics.json",
  "timeout_s": 300,
  "tolerances": {
    "default":               { "atol": 0.0,  "rtol": 0.05 },
    "emf_balance":           { "atol": 0.22, "rtol": 0.0  },
    "emf_consistency":       { "atol": 0.0,  "rtol": 0.08 },
    "emf_zero_sum":          { "atol": 0.03, "rtol": 0.0  },
    "load_torque_dq_ratio":  { "atol": 0.0,  "rtol": 0.35 },
    "load_torque_scaling":   { "atol": 0.0,  "rtol": 0.15 },
    "nl_converged":          { "atol": 0.0,  "rtol": 0.0  },
    "nl_airgap_ratio":       { "atol": 0.06, "rtol": 0.0  },
    "nl_fallback_resid":     { "atol": 1e-5, "rtol": 0.0  }
  }
}
